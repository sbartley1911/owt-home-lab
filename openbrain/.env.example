OPENAI_API_KEY=sk-your-key
OPENBRAIN_CAPTURE_TOKEN=change-this-long-random-token
WHATSAPP_VERIFY_TOKEN=change-this-long-random-token-for-meta-webhook-verification
WHATSAPP_APP_SECRET=meta-app-secret-for-signature-verification

# Your own Postgres server. Requires the pgvector extension.
DATABASE_URL=postgres://openbrain:change-me@localhost:5432/openbrain

# Optional tuning
OPENBRAIN_EMBEDDING_MODEL=text-embedding-3-small
OPENBRAIN_DEFAULT_MATCH_COUNT=8
OPENBRAIN_CAPTURE_PORT=8787
