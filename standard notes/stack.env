# =============================================================================
# Standard Notes — Portainer Stack Environment
# =============================================================================
# Paste this content into the "Environment variables" section when deploying
# the stack in Portainer, OR load it as an env file via the "Load variables
# from .env file" option.
#
# BEFORE DEPLOYING:
#   1. Fill in all values marked CHANGE_ME
#   2. Generate secrets with:  openssl rand -hex 32
#   3. Run the host setup commands below, then deploy the stack
#
# HOST SETUP (run on the Docker host before deploying):
#   export STACK_DATA_DIR=/opt/standardnotes          # or your preferred path
#   mkdir -p $STACK_DATA_DIR/{logs,uploads,data/mysql,data/import,data/redis}
#   curl -o $STACK_DATA_DIR/localstack_bootstrap.sh \
#     https://raw.githubusercontent.com/standardnotes/server/main/docker/localstack_bootstrap.sh
#   chmod +x $STACK_DATA_DIR/localstack_bootstrap.sh
# =============================================================================


# -----------------------------------------------------------------------------
# Host path where all persistent data will be stored
# All sub-directories are created automatically by the host setup commands above
# -----------------------------------------------------------------------------
STACK_DATA_DIR=/opt/standardnotes


# -----------------------------------------------------------------------------
# Ports exposed on the Docker host
# Change these if 3000 or 3125 are already in use on your host
# -----------------------------------------------------------------------------
API_PORT=3000
FILES_PORT=3125


# -----------------------------------------------------------------------------
# Database
# DB_ROOT_PASSWORD and DB_PASSWORD must match the values used on first start.
# Changing them after the database is initialized has no effect without manual
# intervention inside the container.
# -----------------------------------------------------------------------------
DB_DATABASE=standard_notes_db
DB_USERNAME=std_notes_user
DB_ROOT_PASSWORD=42a82d72037bd54871885715ea09863bbd667f9ade934c12c060ebc5daf59856
DB_PASSWORD=10d513f5a779d945a92a244891b0131226eabe2f4cb9135d02c850225ac296da


# -----------------------------------------------------------------------------
# Secrets
# Generate each value with:  openssl rand -hex 32
# Never reuse a value across keys.
# -----------------------------------------------------------------------------
AUTH_JWT_SECRET=b4d4a7434902e9689da0aacf1459fd8605413a93b47949235b4bdab3e9a1821e
AUTH_SERVER_ENCRYPTION_SERVER_KEY=e813cd2c91726a46514c733efd84023c20870bd6252a16db70f04cec236ad008
VALET_TOKEN_SECRET=e0617ba081a776b82aecd37566b89332650869da44e32b337b8d3cd93abcda9f


# -----------------------------------------------------------------------------
# Public files server URL
# Set this to the externally reachable address of the files server.
# Examples:
#   Local network only:  http://192.168.1.100:3125
#   With reverse proxy:  https://notes-files.yourdomain.com
# -----------------------------------------------------------------------------
PUBLIC_FILES_SERVER_URL=https://notesync.office365biz.com
